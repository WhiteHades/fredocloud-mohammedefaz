{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "rm -rf dist && mkdir -p dist && cp -r src prisma prisma.config.js dist/",
    "start": "node src/server.js",
    "lint": "node -e \"process.exit(0)\"",
    "test": "jest --runInBand",
    "db:generate": "prisma generate --config prisma.config.js",
    "db:migrate": "prisma migrate dev --config prisma.config.js",
    "db:deploy": "prisma migrate deploy --config prisma.config.js"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  }
}
